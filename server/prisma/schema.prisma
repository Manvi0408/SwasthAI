datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model AiTriageHistory {
  id           String   @id @default(uuid())
  symptoms     String
  conditions   String   // JSON string of possible conditions
  severity     String   // High, Medium, Low
  action       String   // Recommended action
  hospitalType String   // Type of hospital to visit
  timestamp    DateTime @default(now())
}

model EmergencyRequest {
  id        String   @id @default(uuid())
  category  String   // Cardiac, Accident, Stroke, etc.
  status    String   @default("PENDING") // PENDING, RESPONDING, RESOLVED
  lat       Float
  lng       Float
  address   String?
  timestamp DateTime @default(now())
}


// Master resource datasets
model Hospital {
  id       String @id @default(uuid())
  name     String
  address  String
  type     String // AIIMS, Government, Private, Trauma Center, Cardiac Center, Emergency Center
  services String // Comma separated list
  beds     String
  rating   Float
  phone    String
  lat      Float
  lng      Float
}

model BloodBank {
  id       String @id @default(uuid())
  name     String
  address  String
  city     String
  state    String
  phone    String
  lat      Float
  lng      Float
  aPlus    Int    @default(0)
  aMinus   Int    @default(0)
  bPlus    Int    @default(0)
  bMinus   Int    @default(0)
  oPlus    Int    @default(0)
  oMinus   Int    @default(0)
  abPlus   Int    @default(0)
  abMinus  Int    @default(0)
}

model Pharmacy {
  id      String @id @default(uuid())
  name    String
  address String
  city    String
  state   String
  phone   String
  lat     Float
  lng     Float
}

model Medicine {
  id           String  @id @default(uuid())
  name         String
  genericName  String
  brandPrice   Float
  genericPrice Float
  savings      Float
  description  String?
  category     String?
  availability String  @default("Available")
}
